# Copy this file to .env and fill in your values.
DISCORD_BOT_TOKEN=your_bot_token_here

# Delete the message containing a non-whitelisted file. (true/false)
DELETE_ON_DETECTION=false

# Suppress the public warning reply. Detections are still logged if LOG_CHANNEL_ID is set. (true/false)
SILENT_MODE=false

# ID of the channel to send detection logs to. Leave blank to disable.
LOG_CHANNEL_ID=
